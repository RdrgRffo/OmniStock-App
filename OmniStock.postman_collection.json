{
	"info": {
		"name": "OmniStock API",
		"description": "Coleccion completa de endpoints de la API de OmniStock para verificar el despliegue.\n\nInstrucciones:\n1. Ejecuta primero '1. Auth - Login' para obtener el token\n2. El token se guarda automaticamente en la variable 'token'\n3. El resto de endpoints usaran el token automaticamente",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "username",
			"value": "",
			"type": "string"
		},
		{
			"key": "password",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Auth - Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.success && jsonData.data && jsonData.data.token) {",
							"    pm.collectionVariables.set('token', jsonData.data.token);",
							"    console.log('Token guardado correctamente');",
							"} else {",
							"    console.log('Error al obtener token:', JSON.stringify(jsonData));",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "auth", "login"]
				}
			}
		},
		{
			"name": "2. Analytics - Price Variation",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/analytics/price-variation?months=6&outlierThreshold=50",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "analytics", "price-variation"],
					"query": [
						{ "key": "months", "value": "6" },
						{ "key": "outlierThreshold", "value": "50" }
					]
				}
			}
		},
		{
