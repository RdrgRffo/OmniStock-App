# =============================================================================
# OmniStock — Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores:
#   copy .env.example .env
# =============================================================================

# --- Base de Datos (MariaDB) ---
SPRING_DATASOURCE_URL=jdbc:mariadb://mariadb-local:3306/omnistockdb
SPRING_DATASOURCE_USERNAME=omnistock_user
SPRING_DATASOURCE_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=rootpassword

# --- JWT ---
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres, usar HMAC-SHA256)
JWT_SECRET_KEY=changeme_minimo_32_caracteres_para_hmac_sha256

# --- Encryption (AES) ---
APP_SECURITY_SECRET_KEY=changeme_minimo_32_caracteres_para_hmac_sha256

# --- Host Ports (docker-compose) ---
# Estos valores los asigna automáticamente find_free_ports.ps1
# Si no se definen, docker-compose usa los defaults (${HOST_PORT_*:-default})
# HOST_PORT_DB=3306
# HOST_PORT_MOCK1=3001
# HOST_PORT_MOCK2=3002
# HOST_PORT_MOCK3=3003
# HOST_PORT_MOCK4=3004
# HOST_PORT_API=8080
# HOST_PORT_FRONTEND=8092
