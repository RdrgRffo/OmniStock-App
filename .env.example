# ======================================
# OmniStock - ejemplo de variables de entorno
# Copia este archivo a ".env" y completa.
# ======================================

# --- Base de datos local (servicio mariadb-local) ---
SPRING_DATASOURCE_URL=jdbc:mariadb://mariadb-local:3306/omnistockdb?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=inventario
SPRING_DATASOURCE_PASSWORD=change-me-db-password

# --- Seguridad ---
# app.security.secret-key: AES 16, 24 o 32 chars
APP_SECURITY_SECRET_KEY=0123456789abcdef
# jwt.secret-key: minimo 32 chars
JWT_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Grafana (opcional) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin
