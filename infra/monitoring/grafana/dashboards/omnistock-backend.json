            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"inventory\", area=\"heap\"}",
          "legendFormat": "Heap usado",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"inventory\", area=\"heap\"}",
          "legendFormat": "Heap max",
          "refId": "B"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"inventory\", area=\"heap\"}",
          "legendFormat": "Heap committed",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "Memoria JVM (No-Heap)",
